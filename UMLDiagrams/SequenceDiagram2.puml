@startuml
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBackgroundColor #FAFAFA
skinparam sequenceParticipantBorderColor #CCCCCC
skinparam sequenceLifeLineBorderColor #AAAAAA
skinparam sequenceBoxBackgroundColor #F5F5FF
skinparam noteBorderColor #CCCCCC
skinparam noteBackgroundColor #FFF8DC

title EventHub: Key Sequence Diagram

actor Student
actor "Club Admin" as CA
actor "System Admin" as SA
participant "Frontend\n(Browser)" as FE
participant "JWTAdapter\n[Adapter]" as JWT
participant "Django View" as VIEW
participant "RegistrationFactory\n[Factory]" as FAC
participant "Event.clone()\n[Prototype]" as PROTO
participant "NotificationBuilder\n[Builder]" as NB
participant "Django Signals\n[Observer]" as SIG
database "Database" as DB


Student -> FE : Click "Sign Up for Event"
FE -> VIEW : POST /api/events/<id>/register/
VIEW -> DB : get Event by id
DB --> VIEW : Event (capacity=50)
VIEW -> FAC : RegistrationFactory(event)
FAC -> DB : COUNT confirmed registrations
DB --> FAC : 49 confirmed
FAC -> FAC : 49 < 50 → REGISTERED
FAC -> DB : EventRegistration.get_or_create(\n  user, defaults={status: REGISTERED})
DB --> FAC : (registration, created=True)
FAC --> VIEW : (registration, True)

VIEW -> SIG : post_save fired on EventRegistration
SIG -> SIG : detect created=True, status=REGISTERED
SIG -> NB : NotificationBuilder()\n  .recipient(student)\n  .for_registration_confirmed(event)\n  .build()
NB -> DB : Notification.objects.create(...)
DB --> NB : Notification saved
SIG --> VIEW : done

VIEW --> FE : 201: Created registration
FE --> Student : "You are registered"

@enduml